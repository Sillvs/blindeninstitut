# =============================================================================
# Eltern-Infobogen Generator — Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# LLM provider (required)
# -----------------------------------------------------------------------------

# API key for the LLM provider. Required.
# - OpenAI (default):       sk-...
# - Azure OpenAI EU:        Azure-issued key
# - Local Ollama/vLLM:      any non-empty string (e.g. "local")
OPENAI_API_KEY=

# Optional: override the LLM endpoint for DSGVO-conform deployments.
# Leave unset to use OpenAI's default (api.openai.com — US).
# Examples:
#   OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   OPENAI_BASE_URL=http://ollama.internal:11434/v1
#   OPENAI_BASE_URL=https://vllm.intern.blindeninstitut.de/v1
OPENAI_BASE_URL=

# Optional: model name. Defaults to "gpt-4o".
# For local models match the name as exposed by the endpoint:
#   LLM_MODEL=llama3.1:70b
#   LLM_MODEL=qwen2.5-72b-instruct
LLM_MODEL=

# -----------------------------------------------------------------------------
# Security (required in production)
# -----------------------------------------------------------------------------

# Bearer-token gate for /api/* routes. Required (min. 16 chars) outside dev.
# Generate with: openssl rand -hex 32
# When NODE_ENV is anything other than `development` and this is unset,
# /api/* returns 503 (fail-closed).
API_TOKEN=

# Optional: name of the HTTP header the deployment edge populates with the
# real client IP. Default is to read `x-forwarded-for` (Vercel, Cloudflare,
# standard reverse-proxy setups). Override only if your edge uses a custom
# header.
#   TRUSTED_CLIENT_IP_HEADER=cf-connecting-ip
TRUSTED_CLIENT_IP_HEADER=
